<%-layout("layouts/boilerPlate") %>
    <style>
        #filters {
            display: flex;
            margin-top: 2rem;
            gap: 2rem;
            overflow-x: auto;
            white-space: nowrap;
            padding-bottom: 0.8rem;
            -webkit-overflow-scrolling: touch;
        }

        #filters {
            .filter {
                text-decoration: none;
                color: inherit;
            }

        }

        .filter.active {
            opacity: 1;
            border-bottom: 2px solid black;
        }

        #filters:hover {
            opacity: 1;
            cursor: pointer;
        }

        .tax-info {
            display: none;
        }

        .toggle-switch {
            border: 1px solid black;
            border-radius: 1rem;
            height: 3rem;
            padding: 1rem;
            display: flex;
            justify-content: center;
            align-items: center;
            margin-left: auto;
            flex-shrink: 0;
        }

        @media (max-width: 767.98px) {
            #filters {
                gap: 1.2rem;
                margin-top: 1.2rem;
            }

            .toggle-switch {
                min-width: max-content;
                height: auto;
                padding: 0.7rem;
            }
        }
    </style>

    <body>
        <!-- <h1>All Listings</h1> -->
        <!-- <form method="GET" action="/listings/new">
        <button>Create New Listing</button>
    </form> -->
        <div id="filters">

            <!-- All -->
            <a href="/listings" class="filter <%= !selectedCategory ? 'active' : '' %>">
                <div><i class="fa-solid fa-border-all"></i></div>
                <p>All</p>
            </a>

            <!-- Trending -->
            <a href="/listings?category=trending" class="filter <%= selectedCategory === 'trending' ? 'active' : '' %>">
                <div><i class="fa-solid fa-fire"></i></div>
                <p>Trending</p>
            </a>

            <!-- Rooms -->
            <a href="/listings?category=rooms" class="filter <%= selectedCategory === 'rooms' ? 'active' : '' %>">
                <div><i class="fa-solid fa-bed"></i></div>
                <p>Rooms</p>
            </a>

            <!-- Iconic Cities -->
            <a href="/listings?category=iconic_city"
                class="filter <%= selectedCategory === 'iconic_city' ? 'active' : '' %>">
                <div><i class="fa-solid fa-mountain-city"></i></div>
                <p>Iconic Cities</p>
            </a>

            <!-- Mountains -->
            <a href="/listings?category=mountains"
                class="filter <%= selectedCategory === 'mountains' ? 'active' : '' %>">
                <div><i class="fa-solid fa-mountain"></i></div>
                <p>Mountains</p>
            </a>

            <!-- Castles -->
            <a href="/listings?category=castles" class="filter <%= selectedCategory === 'castles' ? 'active' : '' %>">
                <div><i class="fa-solid fa-dungeon"></i></div>
                <p>Castles</p>
            </a>

            <!-- Pools -->
            <a href="/listings?category=pools" class="filter <%= selectedCategory === 'pools' ? 'active' : '' %>">
                <div><i class="fa-solid fa-person-swimming"></i></div>
                <p>Pools</p>
            </a>

            <!-- Farms -->
            <a href="/listings?category=farms" class="filter <%= selectedCategory === 'farms' ? 'active' : '' %>">
                <div><i class="fa-solid fa-building-wheat"></i></div>
                <p>Farms</p>
            </a>

            <!-- Camping -->
            <a href="/listings?category=camping" class="filter <%= selectedCategory === 'camping' ? 'active' : '' %>">
                <div><i class="fa-solid fa-tent"></i></div>
                <p>Camping</p>
            </a>

            <!-- Arctic -->
            <a href="/listings?category=arctic" class="filter <%= selectedCategory === 'arctic' ? 'active' : '' %>">
                <div><i class="fa-solid fa-snowflake"></i></div>
                <p>Arctic</p>
            </a>

        </div>
        <div class="toggle-switch">
            <div class="form-check form-switch form-check-reverse">
                <input class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
                <label class="form-check-label" for="flexSwitchCheckDefault">Display total after taxes</label>
            </div>
        </div>
        </div>
        </div>

        <div class="container mt-4">
            <div class="row">

                <% for(let listing of allListings){ %>

                    <div class="col-lg-4 col-md-6 col-sm-12 mb-4">

                        <a href="/listings/<%= listing._id %>" class="listing-link">

                            <div class="card listing-card h-100 shadow-sm">

                                <img src="<%= listing.image && listing.image.url ? listing.image.url : 'https://images.unsplash.com/photo-1506744038136-46273834b3fb' %>"
                                    class="card-img-top" alt="listing_image">

                                <div class="card-img-overlay"></div>

                                <div class="card-body">

                                    <p class="card-text">
                                        <strong>
                                            <%= listing.title %>
                                        </strong>
                                        <br>
                                        &#8377;<%= (listing.price || 0).toLocaleString("en-IN") %> / night
                                            <i class="tax-info">&nbsp;+18%gst</i>

                                    </p>

                                </div>

                            </div>

                        </a>

                    </div>

                    <% } %>

            </div>
        </div>

        <script>
            let taxSwitch = document.getElementById("flexSwitchCheckDefault");
            taxSwitch.addEventListener("click", () => {
                let taxinfo = document.getElementsByClassName("tax-info")
                for (info of taxinfo) {
                    if (info.style.display != "inline") {
                        info.style.display = "inline";
                    }
                    else {
                        info.style.display = "none";
                    }
                }
            })
        </script>

    </body>