<%-layout("layouts/boilerPlate") %>
    <div class="row mt-3">
        <div class="col-12 col-lg-8 offset-lg-2">
            <h3>
                <%=listing.title%>
            </h3>
        </div>
        <div class="card listing-card col-12 col-lg-8 offset-lg-2">
            <img src="<%=listing.image.url%>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <p class="card-text">
                    <i>
                        <h4>Owned by : <%= (listing.owner && listing.owner.username) ? listing.owner.username : "Anonymous" %>
                        </h4>
                    </i>
                    <li>
                        <%=listing.description%>
                    </li>
                    <li>
                        &#8377;<%= (listing.price || 0).toLocaleString("en-IN") %> / night
                    </li>
                    <li>
                        <%=listing.location%>
                    </li>
                    <li>
                        <%=listing.country%>
                    </li>
                </p>

                <%if(currUser && listing.owner && listing.owner._id.equals(currUser._id)){%>
                    <div style="display: flex; justify-content: center; gap: 10px; align-items: center;">
                        <a href="/listings/<%= listing._id %>/edit" class="mt-3"
                            style="border-color: white; border: none; text-decoration: none; border-radius: 5px; ; color: black; background-color: green; padding: 2.1px;">
                            Edit this listing
                        </a>
                        <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
                            <button class="mt-3"
                                style="border-color:white; border:none;  border-radius: 5px; color: black; font-weight: 600; background-color: red; padding: 2px;">Delete
                                this listing</button>
                        </form>
                    </div>
                    <%}%>

            </div>
            <hr>
        </div>
        <!-- this one is for review -->
        <div class="col-12 col-lg-8 offset-lg-2">
            <%if(currUser){%>
                <h4>Leave a review</h4>
                <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="needs-validation">
                    <div class="mt-3">
                        <label for="comment" class="form-label" style="font-weight:500;">Rating</label>
                        <fieldset class="starability-slot">

                            <input type="radio" id="rate1" name="review[rating]" value="1" />
                            <label for="rate1">1 star</label>

                            <input type="radio" id="rate2" name="review[rating]" value="2" />
                            <label for="rate2">2 stars</label>

                            <input type="radio" id="rate3" name="review[rating]" value="3" />
                            <label for="rate3">3 stars</label>

                            <input type="radio" id="rate4" name="review[rating]" value="4" />
                            <label for="rate4">4 stars</label>

                            <input type="radio" id="rate5" name="review[rating]" value="5" />
                            <label for="rate5">5 stars</label>

                        </fieldset>
                    </div>
                    <div class="mt-3">
                        <label for="comment" class="form-label" style="font-weight:500;">Comment</label>
                        <textarea class="form-control" rows="2" id="comment" name="review[comment]" required></textarea>
                        <div class="invalid-feedback">Please enter some comment</div>
                    </div>
                    <button class="submit_Review mt-3"
                        style=" border-color:white; border-radius: 5px; color: black; font-weight: 600; background-color: teal; padding: 2px;                    ">Submit</button>
                </form>
                <hr>
                <h4>All Reviews</h4>
                <%if(!listing.reviews.length){%>
                    <p>No reviews yet</p>
                    <%} %>


                        <div class="row">
                            <% for ( review of listing.reviews) { %>
                                <div class="card reviewCard col-12 col-md-6 mb-3">
                                    <div class="card-body">
                                        <h5 class="card-title">
                                            @<%= (review.author && review.author.username) ? review.author.username : "Anonymous" %>
                                        </h5>
                                        <p class="starability-result card-text" data-rating="<%=review.rating%>">
                                        </p>
                                        <p class="card-text">
                                            <%=review.comment%>
                                        </p>
                                        <form action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE"
                                            method="POST" class="mb-3">
                                            <button class="btn btn-sm btn-dark">Delete</button>

                                        </form>
                                    </div>
                                </div>
                                <% } %>
                        </div>
        </div>
        <%}%>
            <div class="col-12 col-lg-8 offset-lg-2 mb-3">
                <hr>

                <h3>Where you'll be</h3>
                <div id="map" data-lat="<%= listing.lat %>" data-lng="<%= listing.lng %>" data-title="<%= listing.title %>" style="height:350px; width: 100%;"></div>
                <input type="hidden" name="listing[lat]" id="lat">
                <input type="hidden" name="listing[lng]" id="lng">

            </div>

    </div>
    <script>
document.addEventListener("DOMContentLoaded", function () {

    var mapDiv = document.getElementById("map");
    if (!mapDiv) return;

    var lat = parseFloat(mapDiv.dataset.lat);
    var lng = parseFloat(mapDiv.dataset.lng);
    var title = mapDiv.dataset.title;

    if (!lat || !lng) return;

    var map = L.map('map').setView([lat, lng], 13);

    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19
    }).addTo(map);

    L.marker([lat, lng])
        .addTo(map)
        .bindPopup(title)
        .openPopup();

});
</script>